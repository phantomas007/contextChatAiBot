APP_ENV=prod
APP_DEBUG=0

NGINX_SERVER_NAME=localhost

POSTGRES_DB=―¹ontextChatAiBot
POSTGRES_USER=―¹ontextChatAiBot_user
POSTGRES_PASSWORD=―¹ontextChatAiBot_secret_password

RABBITMQ_USER=rabbitmq_―¹ontextChatAiBot
RABBITMQ_PASSWORD=―¹ontextChatAiBot_secret_password_rabbit
RABBITMQ_VHOST=/

DB_HOST=db
DB_DATABASE=${POSTGRES_DB}
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

MESSENGER_TRANSPORT_DSN=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST:-rabbitmq}:5672${RABBITMQ_VHOST:-/}

# Redis (–Κ–Β―à Symfony). –£ ―²–Β–Κ―É―â–Β–Ι ―Ä–Β–Α–Μ–Η–Ζ–Α―Ü–Η–Η –¥–Μ―è Docker –Ϋ–Β –Ψ–±―è–Ζ–Α―²–Β–Μ―¨–Ϋ–Ψ: REDIS_URL –¥―É–±–Μ–Η―Ä―É–Β―²―¹―è –≤ docker-compose.yml ―É php/worker.
REDIS_URL=redis://redis:6379

###> Telegram ###
# ―²–Β―¹―²–Ψ–≤―΄–Ι ―²–≥ –±–Ψ―²
TELEGRAM_BOT_TOKEN=your_token
TELEGRAM_WEBHOOK_SECRET=your_secret
TELEGRAM_BOT_LINK=https://t.me/―¹ontextChatAiBot
ADMIN_TELEGRAM_USER_ID=your_user_id
###< Telegram ###

###> Ollama ###
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=your_model

# true = local Ollama (docker), false = Runpod serverless
USE_LOCAL_OLLAMA=false

# Runpod (when USE_LOCAL_OLLAMA=false):
RUNPOD_API_KEY=runpod_api_key
# summarize - generation from brick
RUNPOD_ENDPOINT_ID=your_endpoint_id
# summarizeCountBased - aggregation (bricks > 50)
RUNPOD_ENDPOINT_ID_AGGREGATION=your_endpoint_id_aggregation
# summarizeDaily - daily aggregation (DAILY)
RUNPOD_ENDPOINT_ID_DAILY=your_endpoint_id_daily
###< Ollama ###


###> DeepSeek (ask_ai) ###
DEEPSEEK_API_KEY=deepseek_api_key
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
###< DeepSeek ###

APP_STATS_TIMEZONE=

# -----------------------------

# –†–Β–Α–Κ―²–Η–≤–Α―Ü–Η―è –¦–Γ ―¹ –‰–‰ (UTC): –¥–Ϋ–Β–Ι –±–Β–Ζ ask_ai –≤ –Μ–Η―΅–Κ–Β; –Ω–Α―É–Ζ–Α –Φ–Β–Ε–¥―É –Ϋ–Α–Ω–Ψ–Φ–Η–Ϋ–Α–Ϋ–Η―è–Φ–Η –Ψ–¥–Ϋ–Ψ–Φ―É –Ω–Ψ–Μ―¨–Ζ–Ψ–≤–Α―²–Β–Μ―é (cooldown > inactive)
AI_REENGAGE_INACTIVE_DAYS=4
AI_REENGAGE_COOLDOWN_DAYS=5


