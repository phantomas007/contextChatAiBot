# Скопируйте этот файл в .env.local:
#   cp app/.env.local.example app/.env.local
#
# .env.local НЕ добавляется в git.
# Переменные DB_*, OLLAMA_*, REDIS_URL, TELEGRAM_* — из корневого .env / docker-compose.yml (REDIS для Docker часто только в compose).

# Календарный день в app:collect-daily-stats (срез дат в SQL). По умолчанию — Asia/Vladivostok (см. config/services.yaml).
# APP_STATS_TIMEZONE=Asia/Vladivostok

###> Doctrine ###
DATABASE_URL="postgresql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:5432/${DB_DATABASE}?serverVersion=17&charset=utf8"
